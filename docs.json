            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "build/overview",
                  "build/publishing"
                ]
              },
              {
                "group": "Flows",
                "pages": [
                  "build/flows",
                  "build/flows/editor",
                  "build/flows/config",
