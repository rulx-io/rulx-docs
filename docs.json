{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rulx Docs",
  "colors": {
    "primary": "#0094D3",
    "light": "#7FCFF2",
    "dark": "#006F9F"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
